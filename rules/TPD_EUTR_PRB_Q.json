{
  "table_name": "TPD_EUTR_PRB_Q",
  "groups": [
    {
      "name": "related_rdn01",
      "enabled": true,
      "source_table": ["OP_EUTRANCELLTDDPRB","OP_EUTRANCELLFDDPRB"],
      "group_by": [
        "dn",
        "timestamp14(SOURCEFILENAME)"
      ],
      "join_keys": [
        "object_rdn"
      ]
